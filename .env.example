# AWS
AWS_REGION=test region
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
CLOUDFRONT_DOMAIN=

# DynamoDB Tables — use -test suffixed table names (vayu-wallets-test, etc.)
# for local dev and test.vayutransfer.com's Preview env; bare names for Production only.
DYNAMO_WALLETS_TABLE=
DYNAMO_TRANSFERS_TABLE=
DYNAMO_TRANSACTIONS_TABLE=
DYNAMO_DOWNLOADS_TABLE=
DYNAMO_AUDIT_TABLE=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# SES
SES_FROM_EMAIL=noreply@vayutransfer.com
SES_REGION=ap-south-1

# App
NEXT_PUBLIC_APP_URL=
APP_SECRET=
MAX_FILE_SIZE_GB=10
DEFAULT_EXPIRY_HOURS=24

# Google OAuth (VayuTransfer NextAuth login AND VayuStudios' own Google
# Sign-In under /studio/api/auth/google — same Cloud OAuth client, just needs
# each redirect URI registered: /api/auth/callback/google (NextAuth) and
# /studio/api/auth/google/callback (VayuStudios)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# VayuStudio — Auth
STUDIO_JWT_SECRET=
STUDIO_OWNER_EMAIL=
STUDIO_OWNER_PASSWORD=
# Notified when a studio enquiry comes in, or when a studio self-onboards via Google
PLATFORM_OWNER_EMAIL=
# Production: https://studio.vayutransfer.com  |  Preview: leave blank (falls back to APP_URL/studio/home)
NEXT_PUBLIC_STUDIO_URL=

# VayuStudio — S3 + CloudFront
STUDIO_S3_BUCKET=
STUDIO_CLOUDFRONT_DOMAIN=
STUDIO_CLOUDFRONT_KEY_PAIR_ID=
STUDIO_CLOUDFRONT_PRIVATE_KEY=

# VayuStudio — DynamoDB Tables
DYNAMO_STUDIO_STUDIOS_TABLE=
DYNAMO_STUDIO_PROJECTS_TABLE=
DYNAMO_STUDIO_MEDIAFILES_TABLE=
DYNAMO_STUDIO_SELECTIONS_TABLE=
DYNAMO_STUDIO_USERS_TABLE=
DYNAMO_STUDIO_AUDITLOG_TABLE=
DYNAMO_STUDIO_OTP_TABLE=
# VayuStudio — Billing (separate tables from VayuTransfer's own transactions table)
DYNAMO_STUDIO_TRANSACTIONS_TABLE=
DYNAMO_STUDIO_USAGE_TABLE=

# Billing cron (storage grace-period reminder/delete job for VayuStudios) —
# CRON_SECRET is Vercel's own convention: set this exact name and Vercel
# automatically sends it as "Authorization: Bearer <value>" on every
# scheduled invocation defined in vercel.json, no extra config needed.
CRON_SECRET=

# VayuStudio — SMS (OTP)
SNS_REGION=ap-south-1
SNS_PRODUCTION_ENABLED=false

# VayuStudio — Print portal
PRINT_LINK_EXPIRY_SECONDS=604800

# VayuStudio — AI Chatbot (AWS Bedrock)
AWS_BEDROCK_REGION=ap-south-1
# Optional: override model (default is Claude 3 Haiku)
# BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
